# ====================================
# Project Sentinel - 环境变量配置
# ====================================
# 使用方法:
# 1. 将此文件重命名为 .env (去掉 .example 后缀)
# 2. 填入你的真实 API 密钥
# 3. 不要把 .env 提交到 Git!

# Gemini API Key
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 飞书机器人 Webhook URL
# 创建方式: 飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# Telegram Bot 配置（用于 --publish --publish-target telegram）
# 1) 在 Telegram 中 @BotFather 创建机器人，拿到 token
# 2) 获取目标群/私聊 chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
